{
  "expo": {
    "name": "Animi Nava",
    "slug": "animinava",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F2447"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.animinava.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Needed for video sessions",
        "NSMicrophoneUsageDescription": "Needed for video sessions"
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0F2447",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.animinava.app",
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "8a30c6fd-f75c-455c-b1bd-a63fad96576a"
      }
    }
  }
}